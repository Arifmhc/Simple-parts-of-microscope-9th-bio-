  m_Name: e-5
  m_EditorClassIdentifier: 
  questionText: 'What is the function of the mirror?

'
  referenceImage: {fileID: 0}
  explanationText: 'Solution: The plano-concave mirror in the microscope reflects
    surrounding light onto the stage, allowing a sharp and clear image of the object
    or specimen to be observed.

'
  options:
  - 'It reflects the surrounding light on the object. '
  - 'It magnifies the image of the object. '
  - 'Both A and B '
  - 'None of the above '
  correctOptionIndex: 0
