  m_Name: e-2
  m_EditorClassIdentifier: 
  questionText: "The magnification of the simple microscope used is 10\xD7."
  referenceImage: {fileID: 0}
  explanationText: "Solution: In this experiment, a lens with 10\xD7 magnification
    is used to observe a broad view of the permanent slide. With 5\xD7 magnification,
    the components of the slide would not be clearly visible, while 20\xD7 magnification
    would be too high, causing the components to appear overly focused."
  options:
  - '5X '
  - 10X
  - 15X
  - 20X
  correctOptionIndex: 1
